# =============================================================================
# ServiceHub — Environment Variables
# =============================================================================
# How to use:
#   1. Copy this file:  cp .env.example .env
#   2. Edit .env with your values (optional — defaults work for local dev)
#   3. Start services:  docker-compose up --build
#
# IMPORTANT: The .env file is Git-ignored. Never commit real credentials.
# =============================================================================

# --- Database Configuration ---
POSTGRES_URL=jdbc:postgresql://postgres:5432/servicehub
POSTGRES_USER=servicehub
# Local dev default is "servicehub_dev" (matches docker-compose defaults).
# Override in your local .env or CI/prod secrets for non-dev environments.
POSTGRES_PASSWORD=servicehub_dev

# --- Spring Boot Configuration ---
SPRING_PROFILES_ACTIVE=dev # default for local development; override in CI/prod via env
# Local dev default (matches docker-compose default). Override in prod.
JWT_SECRET=localDevSecretKeyForJWT_CHANGE_IN_PRODUCTION

# --- Server Configuration ---
SERVER_PORT=8080

# ---- Email Configuration ---
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USERNAME=email@amalitech.com
EMAIL_PASSWORD=STRONG_PASSWORD_FOR_EMAIL
EMAIL_ADMIN_ADDRESS= admin email for receiving notifications, e.g
