# =============================================================================
# ServiceHub — Environment Variables
# =============================================================================
# How to use:
#   1. Copy this file:  cp .env.example .env
#   2. Edit .env with your values (optional — defaults work for local dev)
#   3. Start services:  docker-compose up --build
#
# IMPORTANT: The .env file is Git-ignored. Never commit real credentials.
# =============================================================================

# --- Database Configuration ---
POSTGRES_URL=jdbc:postgresql://postgres:5432/servicehub
POSTGRES_USER=servicehub
# Example only — set a real password in your local .env (gitignored)
POSTGRES_PASSWORD=change_me_local_only

# --- Spring Boot Configuration ---
SPRING_PROFILES_ACTIVE=dev # default for local development; override in CI/prod via env
# Example only — set a strong secret in your local .env (gitignored)
JWT_SECRET=change_me_local_only

# --- Server Configuration ---
SERVER_PORT=8080
