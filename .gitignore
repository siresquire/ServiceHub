# =============================================================================
# ServiceHub — Git Ignore Rules
# =============================================================================
# Organized by category. Each section explains what is being excluded and why.
# =============================================================================

# --- Java Build Artifacts ---
# Generated by Maven during compilation — never commit these.
target/
*.class
*.jar
*.war

# --- Log Files ---
*.log

# --- IDE Configuration ---
# Each developer uses their own IDE settings; don't force yours on others.
*.iml
.idea/
.vscode/
*.swp
.project
.classpath
.settings/

# --- OS-Generated Files ---
.DS_Store
Thumbs.db

# --- Environment Variables ---
# IMPORTANT: .env contains real secrets. NEVER commit this file.
# Use .env.example as the safe, committed template.
.env
*.env
!.env.example

# --- Python ---
__pycache__/
*.pyc
.venv/
venv/

# --- Node (if applicable for frontend tools) ---
node_modules/

# --- Docker Compose Override ---
# Local overrides are developer-specific.
docker-compose.override.yml

# --- Pre-commit ---
# The secrets baseline is unique per machine.
.secrets.baseline

# --- Agent / AI Generated Files ---
# Prevent generated prompt artifacts from cluttering the repo
*.resolved
*.md.resolved
